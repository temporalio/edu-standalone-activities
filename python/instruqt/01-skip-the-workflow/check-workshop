#!/usr/bin/env bash
set -euo pipefail
cd /root/workshop

# Restart the worker against the learner's source.
pkill -f "python -m webhooks.worker" || true
nohup uv run python -m webhooks.worker > /tmp/worker.log 2>&1 &
sleep 3

# Reset echo state for a clean signal.
curl -fsS -X POST http://localhost:9000/_reset > /dev/null

# Drive the two comparison clients.
uv run python -m webhooks.send_standalone evt_check_001
uv run python -m webhooks.send_via_workflow evt_check_002

# Poll for deliveries.
count=0
for i in {1..30}; do
  count=$(curl -fsS http://localhost:9000/_received | jq -r '.count')
  if [ "$count" -ge 2 ]; then break; fi
  sleep 1
done
if [ "$count" -lt 2 ]; then
  echo "FAIL: expected 2 deliveries in the echo server, got $count"
  echo "Worker log tail:"
  tail -n 30 /tmp/worker.log || true
  exit 1
fi

# Sanity check: a standalone activity ran on webhook-queue.
sa_count=$(temporal activity list \
  --address localhost:7233 \
  --query "TaskQueue='webhook-queue'" \
  -o json 2>/dev/null | jq 'length' || echo 0)
if [ "$sa_count" -lt 1 ]; then
  echo "FAIL: expected >=1 standalone activity on webhook-queue, got $sa_count"
  exit 1
fi

# Sanity check: a workflow ran on webhook-queue.
wf_count=$(temporal workflow list \
  --address localhost:7233 \
  --query "TaskQueue='webhook-queue'" \
  -o json 2>/dev/null | jq 'length' || echo 0)
if [ "$wf_count" -lt 1 ]; then
  echo "FAIL: expected >=1 workflow on webhook-queue, got $wf_count"
  exit 1
fi

echo "PASS: $count deliveries, $sa_count standalone activity, $wf_count workflow"
