#!/usr/bin/env bash
# Soft check: runs validation; logs diagnostics on issues; never blocks the learner.
(
set -euo pipefail
cd /root/workshop/exercises/02-idempotency-and-crash-safety/exercise

# Fresh state.
pkill -9 -f "python -m webhooks.worker" || true
sleep 1
curl -fsS -X POST http://localhost:9000/_reset > /dev/null

# Start worker in background.
nohup uv run python -m webhooks.worker > /tmp/worker.log 2>&1 &
sleep 3

EVT="evt_check_02_$RANDOM"

# Schedule the activity. send_standalone uses start_activity and returns
# immediately; the worker runs the activity independently.
uv run python -m webhooks.send_standalone "$EVT"

# Give the worker time to pick up the task and POST.
sleep 3

# Hard-crash the worker mid-activity. SIGKILL is required - SIGTERM would
# let the sleep finish and the activity complete cleanly, defeating the demo.
pkill -9 -f "python -m webhooks.worker" || true

# Restart worker so the retry can pick up after the timeout fires.
sleep 1
nohup uv run python -m webhooks.worker >> /tmp/worker.log 2>&1 &

# The crashed attempt times out at start_to_close_timeout (20s); the retry
# then runs the activity (POST + 15s sleep). Wait long enough for both.
sleep 35

# Echo server should show exactly 1 delivery for this event_id (idempotency
# dedup'd the retry's duplicate POST).
count=$(curl -fsS http://localhost:9000/_received \
  | jq --arg evt "$EVT" '[.deliveries[] | select(.body.event_id == $evt)] | length')

if [ "$count" -ne 1 ]; then
  echo "FAIL: expected exactly 1 delivery for $EVT, got $count"
  echo "Hint: did you add Idempotency-Key from activity.info().activity_id?"
  echo "Worker log tail:"
  tail -n 20 /tmp/worker.log || true
  exit 1
fi

# The activity should have run at least twice (initial attempt + retry).
attempts=$(temporal activity describe \
  --address localhost:7233 \
  --activity-id "deliver-$EVT" \
  -o json 2>/dev/null | jq -r '.attempt' || echo 0)

if [ "$attempts" -lt 2 ]; then
  echo "FAIL: expected attempt >= 2 (so the retry actually fired), got $attempts"
  echo "Check that the worker was killed before the activity could complete."
  exit 1
fi

echo "PASS: 1 delivery for $EVT, attempt=$attempts (retry was dedup'd)"
) || true
echo "(soft check: advancing regardless of validation result)"
exit 0
