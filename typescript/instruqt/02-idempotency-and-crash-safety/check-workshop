#!/usr/bin/env bash
set -euo pipefail

# After the fix, 3 requests should arrive but only 1 should be processed.
STATS=$(curl -fsS http://localhost:9000/_received)
RECEIVED=$(echo "$STATS" | jq '.received_count // 0')
PROCESSED=$(echo "$STATS" | jq '.processed_count // 0')
DEDUPED=$(echo "$STATS" | jq '.deduped_count // 0')

if [ "$RECEIVED" -ge 3 ] && [ "$PROCESSED" -eq 1 ] && [ "$DEDUPED" -ge 2 ]; then
  echo "3 requests, 1 processed, $DEDUPED deduped. Idempotency key is working."
  exit 0
fi

echo "Expected: received >= 3, processed == 1, deduped >= 2."
echo "Got: received=$RECEIVED processed=$PROCESSED deduped=$DEDUPED"
echo "Add the Idempotency-Key header and re-run send-standalone."
exit 1
