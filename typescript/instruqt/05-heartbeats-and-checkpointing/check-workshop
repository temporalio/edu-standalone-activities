#!/usr/bin/env bash
set -euo pipefail

# After fix: exactly 10 deliveries, no duplicates.
PROCESSED=$(curl -fsS http://localhost:9000/_received | jq '.processed_count // 0')
if [ "$PROCESSED" -eq 10 ]; then
  echo "Exactly 10 deliveries. Checkpoint read on retry worked."
  exit 0
fi

echo "Expected processed_count == 10. Got $PROCESSED."
echo "Read heartbeatDetails[0] on retry in activities.ts and re-run the kill-and-restart test."
exit 1
