#!/usr/bin/env bash
set -euo pipefail

# The attendee should have at least one delivery in the webhook receiver.
COUNT=$(curl -fsS http://localhost:9000/_received | jq '.processed_count // 0')
if [ "$COUNT" -lt 1 ]; then
  echo "No webhook deliveries recorded yet. Run the standalone activity and check the Webhook receiver tab."
  exit 1
fi
echo "Webhook receiver shows $COUNT processed deliveries. Good."
